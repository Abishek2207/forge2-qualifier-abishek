# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Forge Sprint 02 Multi-Agent System
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token (starts with xoxb-) — from your Slack App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token (starts with xapp-) — from Slack App → Basic Information → App-Level Tokens
# Required for Socket Mode (no public URL needed)
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── Slack Channel Names (without #) ──────────────────────────────────────────
# Create these channels in your Slack workspace before running
SLACK_CHANNEL_COMMANDS=commands
SLACK_CHANNEL_ORCHESTRATOR=agent-orchestrator
SLACK_CHANNEL_LOG=agent-log
SLACK_CHANNEL_REVIEW=human-review

# ── Groq API (Hermes — Kimi K2) ──────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=moonshotai/kimi-k2-instruct

# ── Ollama (OpenClaw — Qwen2.5-Coder) ────────────────────────────────────────
# Runs locally — install Ollama from https://ollama.com
# Then run: ollama pull qwen2.5-coder
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder

# ── GitHub Integration ────────────────────────────────────────────────────────
# Personal access token with repo write permissions
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=Abishek2207/forge2-qualifier-abishek
GITHUB_BRANCH=main

# ── System Settings ───────────────────────────────────────────────────────────
# Author info for git commits made by OpenClaw
GIT_AUTHOR_NAME=OpenClaw Agent
GIT_AUTHOR_EMAIL=openclaw@forge2.local
